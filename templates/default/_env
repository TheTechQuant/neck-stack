APP_ENV=production
DOMAIN=__DOMAIN__
CADDY_ACME_EMAIL=__CADDY_ACME_EMAIL__

# Caddy protects this host with HTTP Basic Auth and redirects to Encore Cloud.
ENCORE_DASHBOARD_DOMAIN=__ENCORE_DASHBOARD_DOMAIN__
ENCORE_DASHBOARD_USER=__ENCORE_DASHBOARD_USER__
ENCORE_DASHBOARD_PASSWORD=__ENCORE_DASHBOARD_PASSWORD_DEFAULT__
ENCORE_DASHBOARD_PASSWORD_HASH='__ENCORE_DASHBOARD_PASSWORD_HASH_DEFAULT__'
ENCORE_DASHBOARD_URL=__ENCORE_DASHBOARD_URL__

NUXT_PUBLIC_API_BASE_URL=/api
NUXT_API_INTERNAL_BASE_URL=http://backend:8080
PUBLIC_WEB_URL=https://__DOMAIN__
NUXT_PUBLIC_ENCORE_TOOLBAR=true
NUXT_PUBLIC_ENCORE_TOOLBAR_ENV_NAME=production
# NUXT_PUBLIC_ENCORE_TOOLBAR_SRC=https://encore.dev/encore-toolbar.js?appId=__APP_ID__&envName=production

# Optional SQL/cache settings. They matter only after Encore metadata reports SQLDatabase/CacheCluster declarations.
# POSTGRES_USER=__POSTGRES_USER__
# POSTGRES_PASSWORD=replace-generated-default
# REDIS_PASSWORD=replace-generated-default
# Add app secret env vars here when Encore metadata reports them.

BACKEND_IMAGE=__REGISTRY__/backend:prod
FRONTEND_IMAGE=__REGISTRY__/frontend:prod
# MIGRATIONS_IMAGE=__REGISTRY__/migrations:prod
PROD_PLATFORM=__PROD_PLATFORM__

# Set KOMODO_MIGRATE_WEBHOOK_URL only after SQLDatabase declarations exist.
# Migrations run on the Komodo server so Postgres stays private.
KOMODO_MIGRATE_WEBHOOK_URL=__KOMODO_MIGRATE_WEBHOOK_URL__
KOMODO_DEPLOY_WEBHOOK_URL=__KOMODO_DEPLOY_WEBHOOK_URL__
