# Operator-editable settings.
DOMAIN=__DOMAIN__
PROD_PLATFORM=__PROD_PLATFORM__

# Local secrets.
NECK_DASH_PASSWORD=
NECK_DASH_PASSWORD_HASH=

# Used only by pnpm deploy:komodo for authenticated Komodo listeners.
KOMODO_WEBHOOK_SECRET=

# pnpm komodo:setup asks for KOMODO_API_KEY / KOMODO_API_SECRET once and saves them locally.

# Optional runtime overrides. Only add these after introducing matching Encore resources.
# POSTGRES_PASSWORD=replace-generated-default
# REDIS_PASSWORD=replace-generated-default
# Add Encore secret env vars here when `pnpm infra:encore` reports them.
