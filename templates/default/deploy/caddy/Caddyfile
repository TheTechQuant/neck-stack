{
	email {$CADDY_ACME_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip

	handle_path /api/* {
		reverse_proxy backend:8080
	}

	handle /__encore/* {
		reverse_proxy backend:8080
	}

	handle {
		reverse_proxy frontend:3000
	}
}

{$ENCORE_DASHBOARD_DOMAIN} {
	encode zstd gzip
	basic_auth {
		{$ENCORE_DASHBOARD_USER} {$ENCORE_DASHBOARD_PASSWORD_HASH}
	}
	redir {$ENCORE_DASHBOARD_URL} 302
}
