:8080 {
	encode zstd gzip

	@neckDashProtected {
		path /__neck_dash /__neck_dash/*
		not path /__neck_dash/api/trace
	}
	basic_auth @neckDashProtected {
		{$NECK_DASH_USER} {$NECK_DASH_PASSWORD_HASH}
	}

	@neckDashRoot path /__neck_dash
	redir @neckDashRoot /__neck_dash/ 308

	handle /__neck_dash/api/trace {
		reverse_proxy neckdash:8080
	}

	handle_path /__neck_dash/api/* {
		reverse_proxy neckdash:8080
	}

	handle /__neck_dash/* {
		reverse_proxy neckdash-ui:3000
	}

	handle_path /api/* {
		reverse_proxy backend:8080
	}

	handle /__encore/healthz {
		reverse_proxy backend:8080
	}

	handle {
		reverse_proxy frontend:3000
	}
}
